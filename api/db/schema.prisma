datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = "native"
}

// ─── User ────────────────────────────────────────────────────────────────────
// dbAuth-compatible user model. Soft-deletable via `deletedAt`.
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  hashedPassword      String
  salt                String
  resetToken          String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  // Relations
  documents      Document[]
  settings       UserSettings?
  customThemes   CustomTheme[]
  themeConfig    ThemeConfig?
  journalEntries JournalEntry[]
}

// ─── Document ────────────────────────────────────────────────────────────────
// Main content model with optimistic-locking version, word/char counts, and
// timestamp tracking for offline-first sync.
model Document {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String    @default("Untitled")
  content         String    @default("")
  version         Int       @default(1)
  checksum        String?
  writingMode     String    @default("typewriter")
  wordCount       Int       @default(0)
  charCount       Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  lastSyncedAt    DateTime?
  clientUpdatedAt DateTime?

  // Relations
  snapshots DocumentSnapshot[]
  chapters  Chapter[]

  @@index([userId, deletedAt])
  @@index([userId, updatedAt])
}

// ─── DocumentSnapshot ────────────────────────────────────────────────────────
// Immutable version-history entries. Created on explicit save / auto-snapshot.
model DocumentSnapshot {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  content    String
  version    Int
  checksum   String
  wordCount  Int      @default(0)

  createdAt  DateTime @default(now())

  @@index([documentId, version])
}

// ─── UserSettings ────────────────────────────────────────────────────────────
// Single-row-per-user preferences. JSON fields stored as String (SQLite).
model UserSettings {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Layout
  maxWidth              Int       @default(800)
  activeThemeId         String    @default("classic")
  fontId                String    @default("courier-prime")
  fontSizeOffset        Int       @default(0)
  lineHeight            Float     @default(1.6)
  letterSpacing         Float     @default(0)
  paragraphSpacing      Float     @default(0.5)

  // Syntax highlighting config
  highlightConfig       Json      @default("{\"nouns\":true,\"pronouns\":true,\"verbs\":true,\"adjectives\":true,\"adverbs\":true,\"prepositions\":true,\"conjunctions\":true,\"articles\":true,\"interjections\":true,\"urls\":true,\"numbers\":true,\"hashtags\":true}")

  // View / focus
  viewMode              String    @default("write")
  focusMode             String    @default("none")
  soloMode              String?

  // Feature flags
  syllableAnnotations   Boolean   @default(true)
  rhymeHighlightRadius  Int       @default(4)
  rhymeBoldEnabled      Boolean   @default(true)
  utf8DisplayEnabled    Boolean   @default(false)

  // Onboarding / UI state
  seenSyntaxPanel       Boolean   @default(false)
  mobileWelcomeSeen     Boolean   @default(false)
  breakdownCollapsed    Boolean   @default(false)
  songRhymesCollapsed   Boolean   @default(false)
  songLinesCollapsed    Boolean   @default(true)

  wordTypeOrder         Json?
  themeOverrides        Json      @default("{}")
  themeNames            Json      @default("{}")

  // Sync timestamps
  lastSyncedAt          DateTime?
  clientUpdatedAt       DateTime?
  updatedAt             DateTime  @updatedAt
}

// ─── CustomTheme ─────────────────────────────────────────────────────────────
// User-created themes (max 20 enforced at app layer).
// ID is client-provided (e.g. "custom_123_abcd"), NOT auto-generated.
model CustomTheme {
  id                String    @id // client-provided
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  textColor         String
  backgroundColor   String
  accentColor       String
  cursorColor       String
  strikethroughColor String
  selectionColor    String

  highlightColors   Json
  rhymeColors       Json?

  sortOrder         Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  lastSyncedAt      DateTime?
  clientUpdatedAt   DateTime?

  @@index([userId, deletedAt])
  @@index([userId, sortOrder])
}

// ─── ThemeConfig ─────────────────────────────────────────────────────────────
// Per-user visibility / ordering of built-in + custom themes.
model ThemeConfig {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  hiddenThemeIds           Json      @default("[]")
  themeOrder               Json      @default("[]")
  hasCustomizedVisibility  Boolean   @default(false)

  lastSyncedAt             DateTime?
  clientUpdatedAt          DateTime?
  updatedAt                DateTime  @updatedAt
}

// ─── Chapter ──────────────────────────────────────────────────────────────────
// Chapters belong to a document when using "chapters" or "roman" writing modes.
// Soft-deletable via `deletedAt`. Ordering is managed by `sortOrder`.
model Chapter {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title       String    @default("Untitled Chapter")
  content     String    @default("")
  sortOrder   Int       @default(0)
  wordCount   Int       @default(0)
  charCount   Int       @default(0)
  partNumber  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([documentId, sortOrder])
  @@index([documentId, deletedAt])
}

// ─── JournalEntry ─────────────────────────────────────────────────────────────
// Daily journal entries for the "journal" writing mode. One entry per user per
// date, enforced via unique constraint.
model JournalEntry {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  content     String    @default("")
  wordCount   Int       @default(0)
  mood        String?
  tags        Json      @default("[]")
  prompt      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([userId, entryDate])
  @@index([userId, deletedAt])
  @@index([userId, entryDate])
}
